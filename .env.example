PORT=5000
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/callkaro?appName=Cluster0

JWT_SECRET=callkaro-local-dev-secret-change-me
JWT_EXPIRES_IN=7d

OTP_TTL_MINUTES=10
OTP_LENGTH=4
DEV_OTP=1234

# Gmail + App Password (put real values in .env only — not here)
EMAIL_USER=
EMAIL_APP_PASSWORD=

RAZORPAY_KEY_ID=rzp_test_local_key
RAZORPAY_KEY_SECRET=rzp_test_local_secret
COINS_PER_100_INR=2500

# Receiver onboarding links
# Local:
ONBOARDING_BASE_URL=http://localhost:5174
# Live API server (callkaro.delicod.com) should use:
# ONBOARDING_BASE_URL=https://callkaro-onbaord-receiver.vercel.app

# ───── AWS S3 — File Storage ─────
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=
# AWS_S3_CDN_URL=
# AWS_S3_PUBLIC_READ=false
# AWS_S3_SIGNED_URL_EXPIRES=604800

# Upload size limits (MB). Nginx/proxy must allow at least this much
# (client_max_body_size) or browsers get HTTP 413 before Node runs.
UPLOAD_MAX_IMAGE_MB=5
UPLOAD_MAX_DOC_MB=10
UPLOAD_MAX_VIDEO_MB=64
