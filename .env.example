# ───── AWS S3 — File Storage ─────
# Required: bucket name and region (put real values in .env only — not here)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# IAM credentials (use least-privilege: s3:PutObject, s3:GetObject, s3:DeleteObject)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: custom S3 endpoint (for MinIO, DigitalOcean Spaces, etc.)
# AWS_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Optional: CDN URL prefix (CloudFront etc.) — files will be served from here
# AWS_S3_CDN_URL=https://cdn.yourdomain.com

# Private bucket (default): images use pre-signed GET URLs (fixes 403 Forbidden)
# Set to true ONLY if bucket/objects are publicly readable
# AWS_S3_PUBLIC_READ=false
# AWS_S3_SIGNED_URL_EXPIRES=604800
